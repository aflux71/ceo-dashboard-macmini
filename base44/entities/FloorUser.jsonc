{
  "name": "FloorUser",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Full name of floor user"
    },
    "pin": {
      "type": "string",
      "description": "4-digit PIN code"
    },
    "role": {
      "type": "string",
      "default": "production_labor",
      "description": "User role determining permissions (matches keys in role_permissions settings)"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Whether user can log in"
    },
    "last_login": {
      "type": "string",
      "format": "date-time",
      "description": "Last login timestamp"
    }
  },
  "required": [
    "name",
    "pin",
    "role"
  ]
}